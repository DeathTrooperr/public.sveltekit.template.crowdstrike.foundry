{
  "name": "adapter-falcon",
  "version": "1.0.0",
  "description": "SvelteKit adapter for CrowdStrike Foundry — prerenders your app and rewrites asset paths to relative URLs for Foundry's sandboxed iframe environment",
  "keywords": [
    "adapter",
    "crowdstrike",
    "foundry",
    "sveltekit",
    "svelte",
    "static"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YOUR_ORG/adapter-falcon.git"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@sveltejs/kit": "^2.0.0"
  },
  "devDependencies": {
    "@sveltejs/kit": "^2.0.0",
    "@types/node": "^20.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.5"
  }
}
